<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>jsPsych Experiment</title>
  <!-- jsPsych v7 のメインスクリプトとスタイルシートの読み込み (CDN) -->
  <script src="https://unpkg.com/jspsych@7.3.4"></script>
  <link href="https://unpkg.com/jspsych@7.3.4/css/jspsych.css" rel="stylesheet" type="text/css" />
  
  <!-- html-keyboard-response プラグインの読み込み -->
  <script src="https://unpkg.com/@jspsych/plugin-html-keyboard-response@1.1.3"></script>

  <style>
    /* 仕様1: 背景色を灰色 (#808080) に設定 */
    body {
      background-color: #808080;
      margin: 0;
      padding: 0;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }

    /* jsPsychの全体的なテキストカラーを調整（灰色の背景で見えやすくするため） */
    .jspsych-content {
      color: #ffffff;
      font-family: 'Helvetica Neue', Arial, sans-serif;
    }

    /* 仕様2: 直径100pxの赤い円を定義するCSS */
    .red-circle {
      width: 100px;
      height: 100px;
      background-color: #ff0000; /* 赤色 */
      border-radius: 50%;        /* 円形にする */
      margin: 0 auto;            /* 中央配置用 */
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3); /* 少し立体感を持たせる影 */
    }

    /* 説明テキストのスタイル */
    .instruction-text {
      margin-top: 20px;
      font-size: 18px;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
    }
  </style>
</head>
<body>
  <div id="jspsych-target"></div>

  <script>
    // jsPsychの初期化
    const jsPsych = initJsPsych({
      display_element: 'jspsych-target',
      on_finish: function() {
        // 実験全体の終了時にデータをコンソールに出力（デバッグ用）
        console.log("実験終了");
        jsPsych.data.get().localSave('csv', 'mydata.csv'); // オプション: データをCSVで保存可能
      }
    });

    // タイムラインの作成
    const timeline = [];

    // 1. 赤い円を表示する試行
    const circle_trial = {
      type: jsPsychHtmlKeyboardResponse,
      // 仕様2: DIVタグとCSSで直径100pxの赤い円を描画
      stimulus: `
        <div style="text-align: center;">
          <div class="red-circle"></div>
          <p class="instruction-text">スペースキーを押すと進みます</p>
        </div>
      `,
      // 仕様3: スペースキー (' ') が押されるまで表示し続ける
      choices: [' '], 
    };
    timeline.push(circle_trial);

    // 2. 終了メッセージを表示する試行
    const end_trial = {
      type: jsPsychHtmlKeyboardResponse,
      stimulus: `
        <div style="text-align: center;">
          <h2 style="font-size: 24px; margin-bottom: 10px;">実験終了</h2>
          <p style="font-size: 16px;">ご協力ありがとうございました。</p>
        </div>
      `,
      choices: "NO_KEYS", // キー入力を受け付けず、表示したままにする（または一定時間で自動終了させることも可能）
    };
    timeline.push(end_trial);

    // 実験の実行
    jsPsych.run(timeline);
  </script>
</body>
</html>
